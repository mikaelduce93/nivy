# Copy to .env.local for local dev. Never commit real secrets.

# ============================================================
# App / URLs
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (do NOT expose to the browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Payments - Stripe
# ============================================================
# Test keys (prefix sk_test_ and pk_test_)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Production keys (prefix sk_live_ and pk_live_)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook secret (from Stripe Dashboard > Webhooks)
# Required for secure webhook verification
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# Payments - CMI (Maroc)
# ============================================================
CMI_MERCHANT_ID=
CMI_API_KEY=
CMI_API_ENDPOINT=https://testpayment.cmi.co.ma/fim/api

# ============================================================
# Emails (Resend)
# ============================================================
RESEND_API_KEY=

# ============================================================
# Cron / scheduled jobs (Vercel Cron calling /api/cron/purge-documents)
# ============================================================
CRON_SECRET=

# ============================================================
# Push notifications (Web Push / VAPID)
# ============================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@teensparty.ma

# ============================================================
# Admin / maintenance flags
# ============================================================
# DANGEROUS: allows server-side execution of allow-listed SQL scripts via /api/admin/execute-sql
ENABLE_ADMIN_SQL_EXECUTION=false
