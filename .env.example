# Copy to .env.local for local dev. Never commit real secrets.

# ============================================================
# App / URLs / Branding
# ============================================================
# Required in production (used as canonical URL, OG tags, redirects, emails).
# In development the app falls back to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: separate base URL used for social shares / referrals (defaults to NEXT_PUBLIC_APP_URL).
NEXT_PUBLIC_SOCIAL_BASE_URL=
NEXT_PUBLIC_BRAND_NAME=Teens Party Morocco

# ============================================================
# Public contact info (exposed in UI)
# ============================================================
NEXT_PUBLIC_SUPPORT_EMAIL=support@teensparty.ma
NEXT_PUBLIC_CONTACT_EMAIL=contact@teensparty.ma
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@teensparty.ma
NEXT_PUBLIC_NOTIFICATIONS_EMAIL=notifications@teensparty.ma
# Optional: dedicated B2B/partners email. Defaults to NEXT_PUBLIC_CONTACT_EMAIL.
NEXT_PUBLIC_PARTNERS_EMAIL=
# International format without "+" (e.g. 212600000000)
NEXT_PUBLIC_WHATSAPP_PHONE=212600000000
# Display format for support phone (any human-readable string)
NEXT_PUBLIC_SUPPORT_PHONE=+212 6 00 00 00 00

# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: explicit project id (otherwise extracted from NEXT_PUBLIC_SUPABASE_URL).
# Used by admin tools to build SQL Editor / dashboard links.
NEXT_PUBLIC_SUPABASE_PROJECT_ID=

# Server-only (do NOT expose to the browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Payments - Stripe
# ============================================================
# Test keys (prefix sk_test_ and pk_test_)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Production keys (prefix sk_live_ and pk_live_)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook secret (from Stripe Dashboard > Webhooks)
# Required for secure webhook verification
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# Payments - CMI (Maroc)
# ============================================================
CMI_MERCHANT_ID=
CMI_API_KEY=
CMI_API_ENDPOINT=https://testpayment.cmi.co.ma/fim/api

# ============================================================
# Emails (Resend)
# ============================================================
RESEND_API_KEY=
# Optional: override sender. If unset, uses
# "<NEXT_PUBLIC_BRAND_NAME> <NEXT_PUBLIC_NOTIFICATIONS_EMAIL>".
RESEND_FROM_EMAIL=

# ============================================================
# Cron / scheduled jobs (Vercel Cron calling /api/cron/purge-documents)
# ============================================================
CRON_SECRET=

# ============================================================
# Push notifications (Web Push / VAPID)
# ============================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@teensparty.ma

# ============================================================
# Admin / maintenance flags
# ============================================================
# DANGEROUS: allows server-side execution of allow-listed SQL scripts via /api/admin/execute-sql
ENABLE_ADMIN_SQL_EXECUTION=false
