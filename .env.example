# Copy this file to .env.local and fill values.
#
# IMPORTANT:
# - Never commit real secrets to git.
# - NEXT_PUBLIC_* vars are exposed to the browser.

# ============================================================================
# Supabase (required)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (required for admin maintenance tasks)
SUPABASE_SERVICE_ROLE_KEY=

# Optional (server-only): if you prefer non-public var names
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Used by admin tools to link to the Supabase dashboard. If unset, extracted
# from NEXT_PUBLIC_SUPABASE_URL (https://<project-id>.supabase.co).
NEXT_PUBLIC_SUPABASE_PROJECT_ID=

# Enable admin SQL runner endpoint (DANGEROUS) - keep disabled in prod unless strictly needed
ENABLE_ADMIN_SQL_EXECUTION=false

# Local dev: optional override of Supabase auth callback URL
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# ============================================================================
# App / URLs / Branding
# ============================================================================
# Required in production. In development defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional override used by some marketing routes. Falls back to NEXT_PUBLIC_APP_URL.
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_API_URL=
API_URL=

NEXT_PUBLIC_APP_VERSION=1.0.0
# Optional: separate base URL for social shares / referrals.
NEXT_PUBLIC_SOCIAL_BASE_URL=
NEXT_PUBLIC_BRAND_NAME=Teens Party Morocco

# Used by CI/health checks to validate staging/prod environments
NEXT_PUBLIC_STAGING_URL=
NEXT_PUBLIC_PROD_URL=

# ============================================================================
# Public contact info (exposed in UI)
# ============================================================================
NEXT_PUBLIC_SUPPORT_EMAIL=support@teensparty.ma
NEXT_PUBLIC_CONTACT_EMAIL=contact@teensparty.ma
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@teensparty.ma
NEXT_PUBLIC_NOTIFICATIONS_EMAIL=notifications@teensparty.ma
# Optional: dedicated B2B/partners email. Defaults to NEXT_PUBLIC_CONTACT_EMAIL.
NEXT_PUBLIC_PARTNERS_EMAIL=
# International format without "+" (e.g. 212600000000)
NEXT_PUBLIC_WHATSAPP_PHONE=212600000000
NEXT_PUBLIC_SUPPORT_PHONE=+212 6 00 00 00 00

# ============================================================================
# Payments (optional / depending on features enabled)
# ============================================================================
# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# CMI (Centre Monetique Interbancaire - Maroc)
CMI_MERCHANT_ID=
CMI_SECRET_KEY=
CMI_API_URL=
CMI_STORE_KEY=
CMI_CLIENT_ID=

# Mobile Money providers (Maroc)
MT_CASH_API_KEY=
MT_CASH_MERCHANT_ID=
INWI_MONEY_API_KEY=
INWI_MONEY_MERCHANT_ID=
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_MERCHANT_ID=

# ============================================================================
# Emails (Resend)
# ============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ============================================================================
# SMS (optional - not yet integrated, declared for future)
# ============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MESSAGEBIRD_ACCESS_KEY=

# ============================================================================
# Cron / Maintenance
# ============================================================================
CRON_SECRET=

# ============================================================================
# AI Content Generation (optional)
# ============================================================================
# Provider: 'openai' or 'claude'
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================================================
# Ready Player Me (optional avatars)
# ============================================================================
READY_PLAYER_ME_SUBDOMAIN=teenparty
READY_PLAYER_ME_API_KEY=

# ============================================================================
# Mapbox (optional - friend map / location features)
# ============================================================================
NEXT_PUBLIC_MAPBOX_TOKEN=

# ============================================================================
# Rate Limiting (Redis/Upstash) - recommended for production
# ============================================================================
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# Analytics / Monitoring
# ============================================================================
NEXT_PUBLIC_VERCEL_ANALYTICS=true
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Server-only webhooks for alerts/incidents
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ============================================================================
# PWA Push Notifications
# ============================================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_PWA_ENABLED=false

# ============================================================================
# Feature Flags (fallback if Edge Config not used)
# ============================================================================
# Format: FEATURE_<FLAG_NAME>=true|false
# See lib/features/flags.ts for the canonical list.
FEATURE_NEW_PAYMENT_METHOD=false
FEATURE_CMI_PAYMENT=false
FEATURE_MOBILE_MONEY_PAYMENT=false
FEATURE_XP_PAYMENT=true
FEATURE_HYBRID_PAYMENT=false
FEATURE_SUBSCRIPTION_PREMIUM=true
FEATURE_GAMIFICATION_V2=true
FEATURE_READY_PLAYER_ME=false
FEATURE_AI_CONTENT_GENERATION=false
FEATURE_STAGING_VALIDATION=false
FEATURE_ENHANCED_MONITORING=true
FEATURE_PWA_OFFLINE_MODE=false

# ============================================================================
# Vercel Edge Config (recommended for production feature flags)
# ============================================================================
# Get from Vercel Dashboard -> Settings -> Edge Config
# Format: https://edge-config.vercel.com/ecfg_xxxxx?token=xxxxx
EDGE_CONFIG=
