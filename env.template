# Copy this file to .env.local and fill values.
#
# IMPORTANT:
# - Never commit real secrets to git.
# - NEXT_PUBLIC_* vars are exposed to the browser.

# ----------------------------
# Supabase (required)
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (required for admin maintenance tasks)
SUPABASE_SERVICE_ROLE_KEY=

# Optional (server-only): if you prefer non-public var names
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Enable admin SQL runner endpoint (DANGEROUS) - keep disabled in production unless strictly needed
ENABLE_ADMIN_SQL_EXECUTION=false

# ----------------------------
# Payments (optional / depending on features enabled)
# ----------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

CMI_MERCHANT_ID=
CMI_SECRET_KEY=

INWI_API_KEY=
ORANGE_API_KEY=
WAVE_API_KEY=

# ----------------------------
# Emails (optional)
# ----------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ----------------------------
# Cron / Maintenance
# ----------------------------
CRON_SECRET=

# ----------------------------
# AI Content Generation (optional)
# ----------------------------
# Provider: 'openai' or 'claude'
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ----------------------------
# Ready Player Me (optional)
# ----------------------------
READY_PLAYER_ME_SUBDOMAIN=teenparty
READY_PLAYER_ME_API_KEY=

# ----------------------------
# Rate Limiting (Redis/Upstash) - Optional but recommended for production
# ----------------------------
# Get these from https://console.upstash.com/
# Free tier: 10K requests/day
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----------------------------
# Analytics / Monitoring (optional)
# ----------------------------
NEXT_PUBLIC_VERCEL_ANALYTICS=true
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ----------------------------
# PWA Push Notifications (optional)
# ----------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=


